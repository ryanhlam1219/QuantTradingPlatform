# ──────────────────────────────────────────────────────────────────────────────
# QuantEdge Trading Platform — Environment Configuration
# Copy this file to .env and fill in your values.
# Lines starting with # are comments. Values marked (optional) can be left blank.
# ──────────────────────────────────────────────────────────────────────────────

# ── Alpaca ────────────────────────────────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
# Paper trading URL (default). Change to https://api.alpaca.markets for live.
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# "iex" for free/paper accounts  |  "sip" for paid full-market-data subscription
ALPACA_DATA_FEED=iex

# ── Database (Phase 8 — not yet connected) ───────────────────────────────────
# TimescaleDB (recommended) or standard PostgreSQL.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/trading_db

# ── Cache (Phase 8 — not yet connected) ──────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Ollama (local LLM for AI research features) ───────────────────────────────
# Install: https://ollama.com  |  Start: ollama serve  |  Pull: ollama pull llama3
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Observability (Phase 6/7 — not yet active) ────────────────────────────────
# LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
# LOG_FORMAT=text         # text | json
# PROMETHEUS_ENABLED=false

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
PAPER_TRADING=true

# ── Other Brokers (optional stubs — not yet fully integrated) ─────────────────
# KRAKEN_API_KEY=
# KRAKEN_SECRET_KEY=
# BINANCE_API_KEY=
# BINANCE_SECRET_KEY=
