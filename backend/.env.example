# Alpaca API
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# Data feed: "iex" for free/paper accounts, "sip" for paid subscriptions
ALPACA_DATA_FEED=iex

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/trading_db

# Redis
REDIS_URL=redis://localhost:6379

# Kraken (optional)
KRAKEN_API_KEY=
KRAKEN_SECRET_KEY=

# Binance.US (optional)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# App
APP_ENV=development
PAPER_TRADING=true

# Ollama (local LLM for AI market research)
# Install: https://ollama.com  then run: ollama serve && ollama pull llama3
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Ollama (local LLM for AI research features)
# Install: https://ollama.com  |  Start: ollama serve  |  Pull model: ollama pull llama3
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
