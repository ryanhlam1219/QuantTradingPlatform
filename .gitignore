# ─────────────────────────────────────────────
#  QuantEdge Trading Platform — .gitignore
# ─────────────────────────────────────────────

# ── Secrets / environment ──────────────────────────────────────────────────
backend/.env
backend/.env.*
!backend/.env.example
.env
.env.*
!.env.example

# ── Runtime state & logs ───────────────────────────────────────────────────
logs/
*.log
*.log.*
backend/cycle_state.json

# ── PID files (created by start.sh) ───────────────────────────────────────
.backend.pid
.frontend.pid

# ── Python ────────────────────────────────────────────────────────────────
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
backend/**/*.py[cod]
backend/**/*.pyo
backend/**/*.pyd
*.pyc
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
.mypy_cache/
.dmypy.json
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Node / frontend ────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.cache/
*.tsbuildinfo

# ── OS / editor ───────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~

# ── Docker ────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ── Testing artefacts ─────────────────────────────────────────────────────
.pytest_cache/
test-results/
coverage.xml
